{
  "version": 3,
  "pages404": true,
  "appType": "pages",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/provision-manager",
      "regex": "^/admin/provision\\-manager(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/provision\\-manager(?:/)?$"
    },
    {
      "page": "/admin/users",
      "regex": "^/admin/users(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/users(?:/)?$"
    },
    {
      "page": "/api/admin/provision-manager",
      "regex": "^/api/admin/provision\\-manager(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/api/admin/provision\\-manager(?:/)?$"
    },
    {
      "page": "/dashboard/company",
      "regex": "^/dashboard/company(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/company(?:/)?$"
    },
    {
      "page": "/dashboard/seeker",
      "regex": "^/dashboard/seeker(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/seeker(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/seeker/dashboard",
      "regex": "^/seeker/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/seeker/dashboard(?:/)?$"
    },
    {
      "page": "/signup",
      "regex": "^/signup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/signup(?:/)?$"
    },
    {
      "page": "/test-db",
      "regex": "^/test\\-db(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/test\\-db(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}